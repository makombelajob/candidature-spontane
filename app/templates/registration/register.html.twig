{% extends 'base.html.twig' %}

{% block title %}Register
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link
	rel="stylesheet" href="{{ asset('css/signup.css') }}">
{#<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">#}

{% endblock %}

{% block body %}

	{% for flash_error in app.flashes('verify_email_error') %}
		<div class="alert alert-danger" role="alert">{{ flash_error }}</div>
	{% endfor %}


	<div class="signup-wrapper register-bg">
		<div class="signup-card">
			<div class="signup-header">
				<div class="signup-logo">Logo</div>
				<div>
					<h1>Inscription</h1>
					<p class="subtitle">Créez votre compte pour postuler rapidement</p>
				</div>
			</div>

			{{ form_errors(registrationForm) }}

			{{ form_start(registrationForm) }}
			<div class="form-row signup-field">{{ form_row(registrationForm.firstName) }}</div>
			<div class="form-row signup-field">{{ form_row(registrationForm.lastName) }}</div>
			<div class="form-row signup-field">{{ form_row(registrationForm.email) }}</div>
			<div class="form-row signup-field">{{ form_row(registrationForm.plainPassword, { label: 'Mot de passe' }) }}</div>
			<div class="form-row form-check mt-3">{{ form_row(registrationForm.agreeTerms) }}</div>

			<div class="signup-cta text-center">
				<button type="submit" class="btn">S'inscrire</button>
			</div>


			{{ form_end(registrationForm) }}
		</div>
	</div>
{% endblock %}
